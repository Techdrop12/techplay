{
  "name": "techplay",
  "version": "1.0.0",
  "type": "module",
  "description": "TechPlay - Boutique e-commerce high-tech, gadgets innovants. SEO, PWA, IA, securite, animations, performance : full option.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0 --no-error-on-unmatched-pattern",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "analyze": "cross-env ANALYZE=true next build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "echo \"Tests a venir\"",
    "clean": "rimraf .next",
    "audit": "npm audit --audit-level=moderate",
    "prepare": "husky",
    "postinstall": "next telemetry disable",
    "start:prod": "next build && next start -p 3000",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix --no-error-on-unmatched-pattern"
  },
  "dependencies": {
