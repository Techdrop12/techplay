{
  "name": "techplay",
  "version": "1.0.0",
  "type": "module",
  "description": "TechPlay - Boutique e-commerce high-tech, gadgets innovants. SEO, PWA, IA, securite, animations, performance : full option.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0 --no-error-on-unmatched-pattern",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "analyze": "cross-env ANALYZE=true next build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build",
    "clean": "rimraf .next",
    "audit": "npm audit --audit-level=moderate",
    "prepare": "husky",
    "postinstall": "next telemetry disable",
    "start:prod": "next build && next start -p 3000",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix --no-error-on-unmatched-pattern"
  },
  "dependencies": {
    "@auth/mongodb-adapter": "^3.11.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^12.36.0",
    "fuse.js": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.577.0",
    "mongoose": "^9.3.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "next-intl": "^4.8.3",
    "nodemailer": "^8.0.2",
    "openai": "^6.29.0",
    "pdfkit": "^0.17.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-rating-stars-component": "^2.2.0",
    "stripe": "^20.4.1",
    "swr": "^2.4.1",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sentry/nextjs": "^10.43.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "postcss": "^8.5.8",
    "postcss-import": "^16.1.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "glob": "^13.0.0"
  },
  "engines": {
    "node": ">=20.9.0 <23",
    "npm": ">=10"
  },
  "keywords": [
    "nextjs",
    "ecommerce",
    "techplay",
    "pwa",
    "seo",
    "ai",
    "stripe",
    "mongodb",
    "typescript",
    "full-option"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Techdrop12/techplay"
  },
  "sideEffects": false,
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix --quiet"
    ]
  }
}
