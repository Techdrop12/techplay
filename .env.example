# TechPlay – Variables d'environnement (copier en .env.local)
# Voir docs/ENV.md pour la description détaillée par environnement.

# === Requis en production (server) ===
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=   # si webhooks Stripe activés

# === Optionnel (server) ===
STRIPE_API_VERSION=2024-11-20.acacia
MONGODB_URI=
MONGODB_DB=
NEXTAUTH_SECRET=
AUTH_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
ADMIN_REVALIDATE_TOKEN=
CRON_SECRET=
BREVO_API_KEY=
BREVO_SENDER=
BREVO_SENDER_NAME=
# ID du template Brevo pour relance panier abandonné (params: EMAIL, CART_ITEMS, CART_TOTAL, CART_COUNT)
# BREVO_ABANDON_TEMPLATE_ID=
RECAPTCHA_SECRET_KEY=

# Marque (override des constantes)
# BRAND_NAME=
# BRAND_URL=
# BRAND_EMAIL=
# BRAND_ADDRESS=
# BRAND_VAT=
# BRAND_SIRET=
# BRAND_LOGO_PATH=

# === Client (NEXT_PUBLIC_*) – exposées au navigateur ===
NEXT_PUBLIC_SITE_URL=https://techplay.example.com
NEXT_PUBLIC_SITE_NAME=TechPlay
NEXT_PUBLIC_SUPPORT_EMAIL=support@techplay.example.com
NEXT_PUBLIC_LOCALE=fr-FR
NEXT_PUBLIC_CURRENCY=EUR
NEXT_PUBLIC_TWITTER_HANDLE=@techplay

# Analytics (optionnel)
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_GTM_ID=
# NEXT_PUBLIC_GTM_SERVER=
# NEXT_PUBLIC_META_PIXEL_ID=
# NEXT_PUBLIC_HOTJAR_ID=
# NEXT_PUBLIC_CLARITY_ID=
# NEXT_PUBLIC_ANALYTICS_DISABLED=false

# Feature flags / tiers
# NEXT_PUBLIC_CRISP_ID=
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# NEXT_PUBLIC_NOINDEX=0
